# DATABASE_URL=

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ADMIN_EMAILS=

# If DATABASE_URL is omitted, the app falls back to the local seeded file runtime in data/runtime.
# UPLOAD_RUNTIME=local

# Set TRUST_PROXY_IP_HEADERS=true only behind a trusted proxy that normalizes client IP headers.
# TRUST_PROXY_IP_HEADERS=false

# Optional local runtime override for tests or isolated local environments.
# RUNTIME_DATA_DIR=.runtime

# UPLOAD_RUNTIME=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://your-provider-endpoint
# S3_FORCE_PATH_STYLE=
# S3_KEY_PREFIX=
# UPLOAD_TOKEN_SECRET=
# UPLOAD_TOKEN_TTL_MS=
# CRON_SECRET=

# OPENAI_API_KEY=...

# SEMANTIC_REFRESH_MAX_PER_WINDOW=
# SEMANTIC_REFRESH_WINDOW_MS=
# SEMANTIC_REFRESH_COOLDOWN_MS=
